# Standalone mkfile for the LLM-facing assets in this directory.
# Not reached by `./INSTALL` or by `mk install` at the tree root.
#
# Targets:
#   install          — install both skills (acme, rc), the bin/ helpers,
#                      the commands/update-acme.md slash command, and
#                      register the PostToolUse hook in
#                      ~/.claude/settings.json.
#   install-skill    — both SKILL.md files.
#   install-acme-skill — acme/SKILL.md only.
#   install-rc-skill — rc/SKILL.md only.
#   install-bin      — bin/ helpers only (acme-update, acme-sync-recent).
#   install-command  — commands/update-acme.md only.
#   register-hook    — modify settings.json so Claude Code runs
#                      acme-update after Edit/Write/MultiEdit/NotebookEdit.
#   uninstall*       — symmetric removal targets.
#
# Other files in this directory (plan, implement, verify, TODO) are
# prompt templates consumed by hand; nothing installs them.

ACMESKILLDIR=$HOME/.claude/skills/acme
RCSKILLDIR=$HOME/.claude/skills/rc
BINDIR=$ACMESKILLDIR/bin
COMMANDDIR=$HOME/.claude/commands

install:V:	install-skill install-bin install-command register-hook

install-skill:V:	install-acme-skill install-rc-skill

install-acme-skill:V:
	mkdir -p $ACMESKILLDIR
	cp acme/SKILL.md $ACMESKILLDIR/SKILL.md

install-rc-skill:V:
	mkdir -p $RCSKILLDIR
	cp rc/SKILL.md $RCSKILLDIR/SKILL.md

install-bin:V:
	mkdir -p $BINDIR
	cp bin/acme-update      $BINDIR/acme-update
	cp bin/acme-sync-recent $BINDIR/acme-sync-recent
	chmod +x $BINDIR/acme-update $BINDIR/acme-sync-recent

install-command:V:
	mkdir -p $COMMANDDIR
	cp commands/update-acme.md $COMMANDDIR/update-acme.md

register-hook:V:
	rc install-hook.rc add

uninstall:V:	deregister-hook uninstall-command uninstall-bin uninstall-skill

uninstall-skill:V:	uninstall-rc-skill uninstall-acme-skill

deregister-hook:V:
	rc install-hook.rc remove

uninstall-command:V:
	rm -f $COMMANDDIR/update-acme.md

uninstall-bin:V:
	rm -f $BINDIR/acme-update $BINDIR/acme-sync-recent

uninstall-acme-skill:V:
	rm -f $ACMESKILLDIR/SKILL.md

uninstall-rc-skill:V:
	rm -f $RCSKILLDIR/SKILL.md
