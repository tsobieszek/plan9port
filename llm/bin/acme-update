#!/usr/local/plan9/bin/rc
# acme-update — Claude Code PostToolUse hook + manual sync helper.
#
# Modes:
#   acme-update                # hook mode: JSON event read from stdin
#   acme-update FILE [TOOL]    # file mode: sync one file by path
#
# Behaviour for Edit / Write / MultiEdit / NotebookEdit on file F:
#   - Existing acme window, clean: write `get`, then best-effort
#     `dot=addr` to the range spanning the modification (first to last
#     non-blank line of `new_string`), then `show`. Falls back to a
#     single line, or line 1, when the lookup fails.
#   - Existing acme window, dirty: report in `+Errors` via acme/cons,
#     do not touch the buffer (matches the project's hard rule).
#   - No window, file exists on disk: open a new window for any of
#     the supported tools (Write / Edit / MultiEdit / NotebookEdit).
#   - Otherwise: no-op.
#
# Exits 0 on success and on every recoverable failure (acme not running,
# jq missing, file unknown). A hook that exits non-zero would surface as
# an error to the user, which is never what we want here.
#
# Dependencies: 9p (plan9port), jq, awk, grep, sed.

# Silent no-op if tooling missing.
if (! jq --version >/dev/null >[2]/dev/null) exit 0

# Silent no-op if acme is not reachable (no namespace, not running, etc.).
if (! 9p read acme/index >/dev/null >[2]/dev/null) exit 0

tool=''
file=''
needle=''

nl='
'

if (~ $#* 0) {
	# Hook mode.
	payload=`''{cat}
	if (~ $payload '') exit 0
	tool=`$nl{echo -n $payload | jq -r '.tool_name // empty'}
	if (! ~ $tool Edit Write MultiEdit NotebookEdit) exit 0
	file=`$nl{echo -n $payload | jq -r '
		.tool_input.file_path
		// .tool_input.notebook_path
		// empty
	'}
	needle=`''{echo -n $payload | jq -r '
		if .tool_name == "MultiEdit" then
			(.tool_input.edits | last.new_string)
		elif .tool_name == "Edit" then
			.tool_input.new_string
		elif .tool_name == "NotebookEdit" then
			(.tool_input.new_source // .tool_input.new_string)
		else empty end // empty
	'}
}
if not {
	file=$1
	tool=$2
	if (~ $tool '') tool=Edit
}

if (~ $file '') exit 0

# First and last non-blank lines of needle, for range-style dot=addr.
# Coerce empty captures (e.g. tool=Write has no needle) back to '',
# otherwise the set_dot call below collapses to fewer args.
first=`$nl{echo -n $needle | sed -n '/[^ 	]/{p;q;}' | sed 's/^[ 	]*//; s/[ 	]*$//'}
last=`$nl{echo -n $needle | awk '/[^ 	]/ { line=$0 } END { if (line != "") print line }' | sed 's/^[ 	]*//; s/[ 	]*$//'}
if (~ $#first 0) first=''
if (~ $#last 0) last=''

# Find the acme window whose tag starts with $file. Returns "<id> <dirty>".
# Done in a single awk pipe: rc has no `return` builtin to break out of a
# `for` loop early, and a per-line `for(line in `$nl{9p read acme/index})`
# would fork awk three times per window.
fn find_window {
	9p read acme/index | awk -v t=$1 '$6 == t { print $1, $5; exit }'
}

# Best-effort selection of the modified range. Looks up $sd_first in
# $sd_path for the start line; if $sd_last differs from $sd_first,
# searches forward from start for the end line. Writes "start,end" to
# acme/<id>/addr, or just "start" (single line), or "1" on miss.
# NB: rc has no `local`. A plain `path=$3` would shadow the global $path
# (rc keeps $path and $PATH in sync) and break every subsequent command,
# so all fn-internal names are prefixed with sd_.
fn set_dot {
	sd_wid=$1 ; sd_first=$2 ; sd_last=$3 ; sd_path=$4
	sd_start=''
	sd_end=''
	if (! ~ $sd_first '') {
		if (test -f $sd_path)
			sd_start=`{awk -v s=$sd_first 'index($0, s) { print NR; exit }' $sd_path}
	}
	if (~ $sd_start '') sd_start=1
	if (! ~ $sd_last '' && ! ~ $sd_last $sd_first) {
		if (test -f $sd_path)
			sd_end=`{awk -v s=$sd_last -v from=$sd_start 'NR>=from && index($0, s) { print NR; exit }' $sd_path}
	}
	if (~ $sd_end '') sd_end=$sd_start
	if (~ $sd_start $sd_end) sd_addr=$sd_start
	if not                   sd_addr=$sd_start^','^$sd_end
	awk -v a=$sd_addr 'BEGIN{printf a}' | 9p write acme/$sd_wid/addr >[2]/dev/null
	echo 'dot=addr' | 9p write acme/$sd_wid/ctl >[2]/dev/null
	echo show       | 9p write acme/$sd_wid/ctl >[2]/dev/null
}

result=`{find_window $file}
winid=`{echo $result | awk '{print $1}'}
dirty=`{echo $result | awk '{print $2}'}

if (~ $winid '') {
	# No existing window. Open one for any supported tool when the
	# file is present on disk.
	if (~ $tool Write Edit MultiEdit NotebookEdit) {
		if (test -f $file) {
			ctl=`{9p read acme/new/ctl}
			newid=`{echo $ctl | awk '{print $1}'}
			if (! ~ $newid '') {
				echo 'name '^$file | 9p write acme/$newid/ctl >[2]/dev/null
				echo get          | 9p write acme/$newid/ctl >[2]/dev/null
				set_dot $newid $first $last $file
			}
		}
	}
	exit 0
}

if (~ $dirty 1) {
	echo '[acme-update] '^$file^' was edited by Claude but the acme window is dirty; not reloaded.' \
		| 9p write acme/cons >[2]/dev/null
	exit 0
}

# Clean window: reload from disk, then refocus.
echo get | 9p write acme/$winid/ctl >[2]/dev/null
set_dot $winid $first $last $file
exit 0
