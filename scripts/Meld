#!/usr/local/plan9/bin/rc

meld_tmp=''

fn cleanup {
	if (! ~ $meld_tmp '')
		rm -f $meld_tmp
}

fn sigterm { cleanup; exit }
fn sigint  { cleanup; exit }
fn sighup  { cleanup; exit }
fn sigquit { cleanup; exit }

if (~ $samfile '') {
	echo 'Meld: no file associated with this window' >[1=2]
	exit usage
}

meld_tmp=/tmp/meld.$pid
9p read acme/$winid/body >$meld_tmp
meld $meld_tmp $samfile &
wait $apid

if (cmp -s $meld_tmp $samfile) {
	awk 'BEGIN{printf "0,$"}' | 9p write acme/$winid/addr
	cat $samfile | 9p write acme/$winid/data

	echo clean | 9p write acme/$winid/ctl
	echo get | 9p write acme/$winid/ctl
}

cleanup
