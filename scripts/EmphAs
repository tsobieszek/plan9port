#!/usr/local/plan9/bin/rc

if (~ $1 '') {
	echo 'usage: EmphAs <language>' >[1=2]
	exit usage
}

lang=$1
emphfile=''
if (test -f $PLAN9/lib/emph.regexp) {
	emphfile=$PLAN9/lib/emph.regexp
}
if not if (test -f $HOME/lib/emph.regexp) {
	emphfile=$HOME/lib/emph.regexp
}
if (~ $emphfile '') {
	exit 'emph.regexp not found'
}
pattern=`{grep '^'$lang'=' $emphfile | sed 's/^[^=]*=//' | head -1}
if (~ $pattern '') {
	exit 'no pattern found for language: '$lang
}

if (~ $winid '') {
	exit 'must be run from acme (winid not set)'
}
ctlfile=acme/$winid/nctl
echo emph=$pattern | 9p write $ctlfile >[2]/dev/null
